<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/13" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mankelfas.controller.KeluhanDetailController" style="-fx-background-color: #FAFAFA;">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   
   <Label text="Detail Keluhan &amp; Fasilitas">
      <font>
         <Font name="Montserrat Bold" size="20.0" />
      </font>
   </Label>

   <VBox spacing="10.0" style="-fx-border-color: #ccc; -fx-border-width: 1; -fx-padding: 10;">
       <Label text="Informasi Keluhan">
          <font><Font name="System Bold" size="14.0"/></font>
       </Label>
       <Label fx:id="lblIdKeluhan" text="ID: " />
       <Label fx:id="lblStatus" text="Status: " />
       <Label fx:id="lblDeskripsi" text="Deskripsi: " wrapText="true"/>
   </VBox>

   <VBox spacing="10.0" style="-fx-border-color: #ccc; -fx-border-width: 1; -fx-padding: 10;">
       <Label text="Informasi Fasilitas">
          <font><Font name="System Bold" size="14.0"/></font>
       </Label>
       <Label fx:id="lblNamaFasilitas" text="Nama: " />
       <Label fx:id="lblLokasi" text="Lokasi: " />
       <Label fx:id="lblKategori" text="Kategori: " />
       <Label fx:id="lblKondisi" text="Kondisi Terakhir: " />
   </VBox>

   <VBox spacing="10.0" style="-fx-border-color: #ccc; -fx-border-width: 1; -fx-padding: 10;" VBox.vgrow="ALWAYS">
       <Label text="Riwayat &amp; Komentar">
          <font><Font name="System Bold" size="14.0"/></font>
       </Label>
       <TextArea fx:id="txtAreaRiwayat" editable="false" VBox.vgrow="ALWAYS" />
   </VBox>

   <Button text="Tutup Detail" onAction="#tutupDetail" style="-fx-background-color: #607D8B; -fx-text-fill: white;" />
</VBox>
