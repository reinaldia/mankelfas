<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/13" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mankelfas.controller.AkunController" styleClass="card">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   
   <Label text="Daftar Akun Pengguna">
      <font>
         <Font name="Montserrat Bold" size="24.0" />
      </font>
   </Label>

   <TableView fx:id="tabelAkun" VBox.vgrow="ALWAYS">
       <columns>
           <TableColumn fx:id="colId" text="ID" prefWidth="50" />
           <TableColumn fx:id="colNama" text="Nama" prefWidth="150" />
           <TableColumn fx:id="colEmail" text="Email" prefWidth="200" />
           <TableColumn fx:id="colRole" text="Role" prefWidth="100" />
           <TableColumn fx:id="colEkstra" text="Info Tambahan" prefWidth="150" />
       </columns>
   </TableView>

   <HBox spacing="10.0" alignment="CENTER_LEFT">
       <Button text="Tambah Akun" onAction="#bukaFormTambah" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" />
       <Button text="Edit" onAction="#bukaFormEdit" style="-fx-background-color: #2196F3; -fx-text-fill: white;" />
       <Button text="Hapus" onAction="#hapusAkun" style="-fx-background-color: #f44336; -fx-text-fill: white;" />
       <HBox HBox.hgrow="ALWAYS" />
       <Button text="Tutup" onAction="#tutupWindow" style="-fx-background-color: #9E9E9E; -fx-text-fill: white;" />
   </HBox>
</VBox>
