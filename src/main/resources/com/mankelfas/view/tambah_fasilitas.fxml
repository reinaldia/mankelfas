<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/13" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.mankelfas.controller.TambahFasilitasController" styleClass="card">
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
   
   <Label text="Tambah Fasilitas Baru">
      <font>
         <Font name="Montserrat Bold" size="20.0" />
      </font>
   </Label>

   <VBox spacing="10.0">
       <Label text="Nama Fasilitas" />
       <TextField fx:id="inputNama" promptText="Contoh: Proyektor Ruang A1" />
       
       <Label text="Kategori" />
       <ComboBox fx:id="comboKategori" promptText="Pilih Kategori..." maxWidth="Infinity"/>
       
       <Label text="Lokasi Ruangan" />
       <TextField fx:id="inputLokasi" promptText="Contoh: Gedung A, Lantai 1" />
       
       <Label text="Kondisi Awal" />
       <ComboBox fx:id="comboKondisi" promptText="Pilih Kondisi..." maxWidth="Infinity"/>
   </VBox>

   <HBox spacing="10.0" alignment="CENTER_RIGHT">
       <Button text="Batal" onAction="#tutupWindow" style="-fx-background-color: #9E9E9E; -fx-text-fill: white;" />
       <Button text="Simpan Fasilitas" onAction="#simpanFasilitas" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" />
   </HBox>
</VBox>
